@article{dipietroRapidRobustOptogenetic2021,
  title = {Rapid and Robust Optogenetic Control of Gene Expression in {{Drosophila}}},
  author = {Di Pietro, Florencia and Herszterg, Sophie and Huang, Anqi and Bosveld, Floris and Alexandre, Cyrille and Sanc{\'e}r{\'e}, Lucas and Pelletier, St{\'e}phane and Joudat, Amina and Kapoor, Varun and Vincent, Jean-Paul and Bella{\"i}che, Yohanns},
  year = 2021,
