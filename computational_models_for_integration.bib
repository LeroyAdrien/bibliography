  langid = {english},
  note = {use of CVM to model large scale embryo movements},
  file = {/Users/adrienleroy/Zotero/storage/H9ENHV2U/Rauzi et al. - 2015 - Embryo-scale tissue mechanics during Drosophila ga.pdf}
}

@article{sandersiusEmergentCellTissue2011,
