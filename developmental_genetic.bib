@article{
  title = {Dynamic Control of Positional Information in the Early {{Drosophila}} Embryo},
  author = {Jaeger, Johannes and Surkova, Svetlana and Blagov, Maxim and Janssens, Hilde and Kosman, David and Kozlov, Konstantin N. and Manu, null and Myasnikova, Ekaterina and {Vanario-Alonso}, Carlos E. and Samsonova, Maria and Sharp, David H. and Reinitz, John},
  year = 2004,
  month = jul,
  journal = {Nature},
  volume = {430},
  number = {6997},
  pages = {368--371},
  issn = {1476-4687},
  doi = {10.1038/nature02678},
  abstract = {Morphogen gradients contribute to pattern formation by determining positional information in morphogenetic fields. Interpretation of positional information is thought to rely on direct, concentration-threshold-dependent mechanisms for establishing multiple differential domains of target gene expression. In Drosophila, maternal gradients establish the initial position of boundaries for zygotic gap gene expression, which in turn convey positional information to pair-rule and segment-polarity genes, the latter forming a segmental pre-pattern by the onset of gastrulation. Here we report, on the basis of quantitative gene expression data, substantial anterior shifts in the position of gap domains after their initial establishment. Using a data-driven mathematical modelling approach, we show that these shifts are based on a regulatory mechanism that relies on asymmetric gap-gap cross-repression and does not require the diffusion of gap proteins. Our analysis implies that the threshold-dependent interpretation of maternal morphogen concentration is not sufficient to determine shifting gap domain boundary positions, and suggests that establishing and interpreting positional information are not independent processes in the Drosophila blastoderm.},
  langid = {english},
  pmid = {15254541},
  keywords = {Animals,Blastoderm,Body Patterning,Diffusion,Drosophila melanogaster,Drosophila Proteins,Embryo Nonmammalian,Female,Gene Expression Regulation Developmental,Models Biological,review_2604_4:positional-info,RNA Messenger,Time Factors},
  note = {\% ~ - **Step 1: First Interpretation - From Gradient to Broad Domains (Gap Genes).** The process begins with the direct interpretation of the maternal Bicoid gradient, which acts as a morphogen to activate gap genes like *hunchback* in a concentration-dependent manner. This creates a coarse initial pattern. Crucially, this pattern is immediately refined; the gap genes themselves interact via mutual repression (e.g., *giant* and *Kr\"uppel*), sharpening their expression boundaries and creating the first set of discrete, stable territories.}
}

@article{
  title = {Regulation of Even-Skipped Stripe 2 in the {{Drosophila}} Embryo},
  author = {Small, S. and Blair, A. and Levine, M.},
  year = 1992,
  month = nov,
  journal = {The EMBO journal},
  volume = {11},
  number = {11},
  pages = {4047--4057},
  issn = {0261-4189},
  doi = {10.1002/j.1460-2075.1992.tb05498.x},
  abstract = {In an effort to determine how crude gradients of transcriptional activators and repressors specify sharp stripes of gene expression in the early embryo, we have conducted a detailed study of even-skipped (eve) stripe 2. A combination of promoter fusions and P-transformation assays were used to show that a 480 bp region of the eve promoter is both necessary and sufficient to direct a stripe of LacZ expression within the limits of the endogenous eve stripe 2. The maternal morphogen bicoid (bcd) and the gap proteins hunchback (hb), Kruppel (Kr) and giant (gt) all bind with high affinity to closely linked sites within this small promoter element. Activation appears to depend on cooperative interactions among bcd and hb proteins, since disrupting single binding sites cause catastrophic reductions in expression. gt is directly involved in the formation of the anterior border, although additional repressors may participate in this process. Forming the posterior border of the stripe involves a delicate balance between limiting amounts of the bcd activator and the Kr repressor. We propose that the clustering of activator and repressor binding sites in the stripe 2 element is required to bring these weakly interacting regulatory factors into close apposition so that they can function both cooperatively and synergistically to control transcription.},
  langid = {english},
  pmcid = {PMC556915},
  pmid = {1327756},
  keywords = {Animals,Base Sequence,beta-Galactosidase,Binding Sites,Cloning Molecular,DNA Transposable Elements,Drosophila,Embryo Nonmammalian,Gene Expression Regulation,In Situ Hybridization,Molecular Sequence Data,Mutagenesis Site-Directed,Recombinant Fusion Proteins,review_2604_1:history},
  note = {\% ~ - **Step 2: Combinatorial Logic - From Broad Domains to Sharp Stripes (Pair-Rule Genes).** These sharpened gap gene domains provide a combinatorial input for the next tier. The regulatory elements (enhancers) of pair-rule genes function as molecular logic gates. The famous *even-skipped* stripe 2 enhancer, for instance, integrates inputs from multiple gap gene activators and repressors to produce a precise output: a single, sharp stripe of expression. This step transforms broad regions into a periodic pattern, defining the fundamental segmental repeats.
\par
\% ~ ~- Use the eve stripe 2 enhancer as the canonical example of a complex logic gate (AND/NOT logic). Cite the key work from Levine's lab (e.g., Small et al., 1992).},
  file = {/Users/adrienleroy/Zotero/storage/ETDJZQYI/Small et al. - 1992 - Regulation of even-skipped stripe 2 in the Drosoph.pdf}
}

@article{
  title = {The Molecular Genetics of Embryonic Pattern Formation in {{Drosophila}}},
  author = {Ingham, P W},
  year = 1988,
  langid = {english},
  keywords = {review_2604_1:challenges},
  note = {\% ~ - **Step 3: Locking in the Pattern - From Stripes to Cell Fates (Segment Polarity Genes).** The pair-rule stripes, in turn, provide a combinatorial code that positions the segment polarity genes in single-cell-wide domains. At this stage, the mechanism shifts fundamentally: genes like *wingless* and *hedgehog* initiate cell-to-cell signaling pathways. These signals create positive feedback loops between adjacent cells, locking in the parasegment boundaries and making the pattern robust and permanent. This final step not only defines the polarity of each segment but also triggers the downstream effector genes that control the specific physical behaviors of the cells, such as building denticle belts.},
  file = {/Users/adrienleroy/Zotero/storage/QTBJCZBB/Ingham - 1988 - The molecular genetics of embryonic pattern format.pdf}
}

