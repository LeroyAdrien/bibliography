@article{kiehartMultipleForcesContribute2000,
  title = {Multiple Forces Contribute to Cell Sheet Morphogenesis for Dorsal Closure in {{Drosophila}}},
  author = {Kiehart, D. P. and Galbraith, C. G. and Edwards, K. A. and Rickoll, W. L. and Montague, R. A.},
  year = 2000,
  month = apr,
  journal = {The Journal of Cell Biology},
  volume = {149},
