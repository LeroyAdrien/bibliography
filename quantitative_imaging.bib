  shorttitle = {Data for - {{Tracking}} One-in-a-Million},
  author = {Seiffarth, Johannes and Bl{\"o}baum, Luisa and L{\"o}ffler, Katharina and Scherr, Tim and Gr{\"u}nberger, Alexander and Scharr, Hanno and Mikut, Ralf and N{\"o}h, Katharina},
  year = 2022,
