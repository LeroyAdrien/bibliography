@article{sakaguchiSinglecellTranscriptomeAtlas2023,
  title = {Single-Cell Transcriptome Atlas of {{Drosophila}} Gastrula 2.0},
  author = {Sakaguchi, Shunta and Mizuno, Sonoko and Okochi, Yasushi and Tanegashima, Chiharu and Nishimura, Osamu and Uemura, Tadashi and Kadota, Mitsutaka and Naoki, Honda and Kondo, Takefumi},
  year = 2023,
  month = jul,
  journal = {Cell Reports},
  volume = {42},
  number = {7},
  pages = {112707},
  publisher = {Elsevier BV},
  issn = {2211-1247},
  doi = {10.1016/j.celrep.2023.112707},
  urldate = {2025-07-18},
  abstract = {During development, positional information directs cells to specific fates, leading them to differentiate with their own transcriptomes and express specific behaviors and functions. However, the mechanisms underlying these processes in a genome-wide view remain ambiguous, partly because the single-cell transcriptomic data of early developing embryos containing accurate spatial and lineage information are still lacking. Here, we report a single-cell transcriptome atlas of Drosophila gastrulae, divided into 77 transcriptomically distinct clusters. We find that the expression profiles of plasma-membrane-related genes, but not those of transcription-factor genes, represent each germ layer, supporting the nonequivalent contribution of each transcription-factor mRNA level to effector gene expression profiles at the transcriptome level. We also reconstruct the spatial expression patterns of all genes at the single-cell stripe level as the smallest unit. This atlas is an important resource for the genome-wide understanding of the mechanisms by which genes cooperatively orchestrate Drosophila gastrulation.},
  copyright = {https://www.elsevier.com/tdm/userlicense/1.0/},
  langid = {english},
  keywords = {review_2604_3:scrna},
  file = {/Users/adrienleroy/Zotero/storage/UECP2J7R/Sakaguchi et al. - 2023 - Single-cell transcriptome atlas of Drosophila gast.pdf}
}

@article{satijaSpatialReconstructionSinglecell2015,
  title = {Spatial Reconstruction of Single-Cell Gene Expression Data},
  author = {Satija, Rahul and Farrell, Jeffrey A. and Gennert, David and Schier, Alexander F. and Regev, Aviv},
  year = 2015,
  month = may,
  journal = {Nature Biotechnology},
  volume = {33},
  number = {5},
  pages = {495--502},
  issn = {1546-1696},
  doi = {10.1038/nbt.3192},
  abstract = {Spatial localization is a key determinant of cellular fate and behavior, but methods for spatially resolved, transcriptome-wide gene expression profiling across complex tissues are lacking. RNA staining methods assay only a small number of transcripts, whereas single-cell RNA-seq, which measures global gene expression, separates cells from their native spatial context. Here we present Seurat, a computational strategy to infer cellular localization by integrating single-cell RNA-seq data with in situ RNA patterns. We applied Seurat to spatially map 851 single cells from dissociated zebrafish (Danio rerio) embryos and generated a transcriptome-wide map of spatial patterning. We confirmed Seurat's accuracy using several experimental approaches, then used the strategy to identify a set of archetypal expression patterns and spatial markers. Seurat correctly localizes rare subpopulations, accurately mapping both spatially restricted and scattered groups. Seurat will be applicable to mapping cellular localization within complex patterned tissues in diverse systems.},
  langid = {english},
  pmcid = {PMC4430369},
  pmid = {25867923},
  keywords = {Animals,Gene Expression Regulation Developmental,High-Throughput Nucleotide Sequencing,Image Processing Computer-Assisted,In Situ Hybridization Fluorescence,review_2604_3:in-silico-reconstruction,Single-Cell Analysis,Transcriptome,Zebrafish},
  file = {/Users/adrienleroy/Zotero/storage/BUUK3PYG/Satija et al. - 2015 - Spatial reconstruction of single-cell gene expression data.pdf}
}

@article{schottOpenSTHighresolutionSpatial2024,
  title = {Open-{{ST}}: {{High-resolution}} Spatial Transcriptomics in {{3D}}},
  shorttitle = {Open-{{ST}}},
  author = {Schott, Marie and {Le{\'o}n-Peri{\~n}{\'a}n}, Daniel and Splendiani, Elena and Strenger, Leon and Licha, Jan Robin and Pentimalli, Tancredi Massimo and Schallenberg, Simon and Alles, Jonathan and Samut Tagliaferro, Sarah and Boltengagen, Anastasiya and Ehrig, Sebastian and Abbiati, Stefano and Dommerich, Steffen and Pagani, Massimiliano and Ferretti, Elisabetta and Macino, Giuseppe and Karaiskos, Nikos and Rajewsky, Nikolaus},
  year = 2024,
  month = jul,
  journal = {Cell},
  volume = {187},
  number = {15},
  pages = {3953-3972.e26},
  issn = {00928674},
  doi = {10.1016/j.cell.2024.05.055},
  urldate = {2026-05-27},
  abstract = {Spatial transcriptomics (ST) methods unlock molecular mechanisms underlying tissue development, homeostasis, or disease. However, there is a need for easy-to-use, high-resolution, cost-efficient, and 3D-scalable methods. Here, we report Open-ST, a sequencing-based, open-source experimental and computational resource to address these challenges and to study the molecular organization of tissues in 2D and 3D. In mouse brain, Open-ST captured transcripts at subcellular resolution and reconstructed cell types. In primary head-and-neck tumors and patient-matched healthy/metastatic lymph nodes, Open-ST captured the diversity of immune, stromal, and tumor populations in space, validated by imaging-based ST. Distinct cell states were organized around cell-cell communication hotspots in the tumor but not the metastasis. Strikingly, the 3D reconstruction and multimodal analysis of the metastatic lymph node revealed spatially contiguous structures not visible in 2D and potential biomarkers precisely at the 3D tumor/lymph node boundary. All protocols and software are available at https://rajewsky-lab.github.io/openst.},
  langid = {english},
  keywords = {3D_spatial_transcriptomics},
  file = {/Users/adrienleroy/Zotero/storage/YEFUHN6Y/Schott et al. - 2024 - Open-ST High-resolution spatial transcriptomics in 3D.pdf}
}

