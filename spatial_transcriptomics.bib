@article{tsanovSmiFISHFISHquantFlexible2016,
  title = {{{smiFISH}} and {{FISH-quant}} -- a Flexible Single {{RNA}} Detection Approach with Super-Resolution Capability},
  author = {Tsanov, Nikolay and Samacoits, Aubin and Chouaib, Racha and Traboulsi, Abdel-Meneem and Gostan, Thierry and Weber, Christian and Zimmer, Christophe and Zibara, Kazem and Walter, Thomas and Peter, Marion and Bertrand, Edouard and Mueller, Florian},
