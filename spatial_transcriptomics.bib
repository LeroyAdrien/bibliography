@article{chenDissectingMammalianSpermatogenesis2021,
  title = {Dissecting Mammalian Spermatogenesis Using Spatial Transcriptomics},
  author = {Chen, Haiqi and Murray, Evan and Sinha, Anubhav and Laumas, Anisha and Li, Jilong and Lesman, Daniel and Nie, Xichen and Hotaling, Jim and Guo, Jingtao and Cairns, Bradley R. and Macosko, Evan Z. and Cheng, C. Yan and Chen, Fei},
