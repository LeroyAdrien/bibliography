  author = {Di, Xingpeng and Gao, Xiaoshuai and Peng, Liao and Ai, Jianzhong and Jin, Xi and Qi, Shiqian and Li, Hong and Wang, Kunjie and Luo, Deyi},
  year = 2023,
  month = jul,
  journal = {Signal Transduction and Targeted Therapy},
