  pmid = {28778874},
  note = {Epithelia are not just force generators; they are exquisitely sensitive force-sensors. The cytoskeleton and cell junctions act as mechanosensors that convert physical cues (like stretch or substrate stiffness) into biochemical signals. This feedback loop is critical for self-organization and robust morphogenesis.},
